@model Cinema_Ticket_Bocking.ViewModel.BookingVM

<div class="container mt-4">

    <h2>Create Booking</h2>

    <form method="post">

        <div class="mb-3">
            <label class="form-label">Movie</label>
            <select asp-for="Book.MovieId" class="form-select">
                <option value="">-- Select Movie --</option>
                @foreach (var movie in Model.Movies)
                {
                    <option value="@movie.Id">@movie.Name</option>
                }
            </select>
        </div>

      
        <div class="mb-3">
            <label class="form-label">Number of Tickets</label>
            <input asp-for="Book.NumberOfTickets" class="form-control" type="number" min="1" />
        </div>

  
        <div class="mb-3">
            <label class="form-label">Show Time</label>
            <input asp-for="Book.ShowTime" class="form-control" type="datetime-local" />
        </div>

      
        <div class="mb-3">
            <label class="form-label">Total Price</label>
            <input asp-for="Book.TotalPrice" class="form-control" type="number" step="0.01" />
        </div>

    
        <div class="mb-3">
            <label class="form-label">Status</label>
            <select asp-for="Book.Status" class="form-select">
                <option value="true">Confirmed</option>
                <option value="false">Cancelled</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Book Now</button>

    </form>

</div>